# =============================================================================
# Now Playing — Environment Configuration
# Copy this file to .env and fill in the values for the services you use.
# At least one of Plex or Jellyfin must be configured.
# =============================================================================

# -----------------------------------------------------------------------------
# Plex (optional — remove or leave blank if not using Plex)
# -----------------------------------------------------------------------------

# Full URL of your Plex server, including port
PLEX_URL=http://your-plex-server:32400

# Your Plex authentication token.
# Find it by: opening Plex Web → any media item → ⋮ menu → "Get Info" →
# "View XML" — the token is the X-Plex-Token query parameter in the URL.
# Or via: https://support.plex.tv/articles/204059436
PLEX_TOKEN=your_plex_token_here

# -----------------------------------------------------------------------------
# Jellyfin (optional — remove or leave blank if not using Jellyfin)
# -----------------------------------------------------------------------------

# Full URL of your Jellyfin server, including port
JELLYFIN_URL=http://your-jellyfin-server:8096

# Jellyfin API key with admin privileges (required to list all users' history).
# Generate one in: Jellyfin Dashboard → API Keys → +
JELLYFIN_API_KEY=your_jellyfin_api_key_here

# -----------------------------------------------------------------------------
# Spotify (optional — enables "Open in Spotify" links on music cards)
# Note: Requires a Spotify Premium account as of Feb 2026.
# -----------------------------------------------------------------------------

# Create an app at https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------

# Timeout for upstream API requests in milliseconds (default: 8000)
# NEXT_PUBLIC_FETCH_TIMEOUT=8000
